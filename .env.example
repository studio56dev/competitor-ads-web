# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres in docker-compose, override URL in prod)
POSTGRES_DB=competitor_ads
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@db:5432/competitor_ads

# Redis (Celery broker, used in Faz 3)
REDIS_URL=redis://redis:6379/0

# Time zone
TIME_ZONE=Europe/Istanbul
